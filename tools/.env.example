# Backlink Outreach — Environment Variables
# Rename this file to .env and fill in your keys

# Hunter.io API Key
# Get free key at: https://hunter.io/api-keys
# Free plan = 25 searches/month
HUNTER_API_KEY=your_hunter_key_here
# Brevo API Key
# Get from: https://app.brevo.com/settings/keys/api
# You already have a Brevo account for mosquitomanplus.com
BREVO_API_KEY=your_brevo_key_here